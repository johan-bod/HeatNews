# NewsData.io API Key
# Get your free API key at: https://newsdata.io/register
# Free tier: 200 requests/day, commercial use allowed ✅
VITE_NEWSDATA_API_KEY=your_api_key_here

# Firebase Configuration (OPTIONAL - App works without this)
# To set up Firebase authentication:
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project
# 3. Enable Authentication > Google Sign-In
# 4. Go to Project Settings > General > Your apps
# 5. Copy the config values and uncomment lines below

# Firebase settings (from Firebase Console)
# Uncomment and replace with your actual Firebase credentials:
# VITE_FIREBASE_API_KEY=your-api-key-here
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
# VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Admin Emails (comma-separated list of admin user emails)
# Only needed if you enable Firebase authentication
# VITE_ADMIN_EMAILS=your.email@gmail.com

# Google AdSense Configuration (OPTIONAL)
# To monetize your app:
# 1. Create AdSense account at https://adsense.google.com
# 2. Add your site and get approved
# 3. Copy your publisher ID and ad slot IDs
# Note: Set VITE_ADSENSE_TEST_MODE=true to show test placeholders in development
VITE_ADSENSE_CLIENT=ca-pub-your_publisher_id_here
VITE_ADSENSE_SLOT_HORIZONTAL=1234567890
VITE_ADSENSE_TEST_MODE=true
