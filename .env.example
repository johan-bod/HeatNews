# ── Server-side only (set in Vercel dashboard, NOT prefixed with VITE_) ────────
# These are never bundled into the client. Set them in Vercel → Settings → Env Vars.
# For local dev, run `vercel dev` and set them in .env.local (not committed).

NEWSDATA_API_KEY=your_newsdata_key_here
DEEPL_API_KEY=your_deepl_key_here   # Free keys end with :fx

# Optional: custom RSSHub instance URL (default: https://rsshub.app)
# VITE_RSSHUB_BASE_URL=https://your-rsshub.vercel.app
