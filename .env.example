# NewsData.io API Key
# Get your free API key at: https://newsdata.io/register
# Free tier: 200 requests/day, commercial use allowed ✅
VITE_NEWSDATA_API_KEY=your_api_key_here

# DeepL Translation API Key (optional)
# Get your free key at: https://www.deepl.com/en/pro-api
# Free tier: 500k characters/month. Free keys end with ':fx'
# When set, article titles and descriptions are translated to English on demand.
# Leave unset to disable translation (UI gracefully hides toggle).
VITE_DEEPL_API_KEY=your_deepl_key_here
